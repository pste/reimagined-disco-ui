#!/bin/bash
# Valida l'ultimo tag creato ad ogni commit. Se non è valido blocca e permette di crearne uno nuovo corretto.
# Workflow: git tag -a v1.2.3 -m "v1.2.3" → git commit → questo hook valida.

SEMVER_RE='^v([0-9]+)\.([0-9]+)\.([0-9]+)$'

# get latest TAG sorted by version. If no tag exists, exit without errors
LATEST_TAG=$(git for-each-ref refs/tags/ --count=1 --sort=-version:refname --format="%(refname:short)")
if [ -z "$LATEST_TAG" ]; then exit 0; fi

# test semver format on the latest tag
if ! echo "$LATEST_TAG" | grep -qE "$SEMVER_RE"; then
  echo "$LATEST_TAG does not respect the semver format. Commit is blocked!"
  exit 1
fi

# if a previous tag exists, check that latest > previous
PREV_TAG=$(git for-each-ref refs/tags/ --count=2 --sort=-version:refname --format="%(refname:short)" | tail -n 1)
if [ -n "$PREV_TAG" ] && [ "$PREV_TAG" != "$LATEST_TAG" ]; then
  GREATEST=$(printf "%s\n%s\n" "$PREV_TAG" "$LATEST_TAG" | sort -V | tail -n 1)
  if [ "$GREATEST" != "$LATEST_TAG" ]; then
    echo "$LATEST_TAG is not greater than the previous tag $PREV_TAG. Commit is blocked!"
    exit 1
  fi
fi

exit 0